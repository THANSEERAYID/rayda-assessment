# Copy to .env and fill in.

# --- Model -----------------------------------------------------------------
# Needed to run the agent. NOT needed for `make eval` (the deterministic tier
# runs with no model at all).
# A ChatGPT subscription does not include API access — create a key with billing
# enabled at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0
OPENAI_SEED=7

# --- Database --------------------------------------------------------------
# Postgres backs the telemetry tables, the audit log and the LangGraph
# checkpointer that makes a paused approval survive a restart.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fleet_copilot

# --- Email (optional) ------------------------------------------------------
# An approved notify_employee action sends an email. Left unset, sends are
# SIMULATED and recorded (the dataset has no real addresses). To send for real,
# set MAIL_ENABLED=true and the SMTP details below.
MAIL_ENABLED=false
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=Fleet Copilot

# --- Detector thresholds ---------------------------------------------------
# Shared by the tools, the detectors and the evaluation suite so they cannot
# drift apart. See the README for how these were chosen from the data.
DISK_LOW_FREE_PCT=15
DISK_CRITICAL_FREE_PCT=5
RAM_HIGH_USED_PCT=85
RAM_SUSTAINED_RATIO=0.8
BATTERY_HIGH_CYCLE_COUNT=800
BATTERY_CAPACITY_DECLINE_PCT=3

# --- Rate limiting ---------------------------------------------------------
# A token bucket paces requests against the provider's per-minute allowance, so
# a multi-agent turn does not trip a 429 partway through. The semaphore bounds
# how many calls are in flight process-wide, which the bucket alone does not do.
LLM_REQUESTS_PER_SECOND=2.0
LLM_MAX_BUCKET_SIZE=5
LLM_MAX_CONCURRENCY=4

# --- Agent loop bounds -----------------------------------------------------
MAX_TOOL_ITERATIONS=6
MAX_TOOL_RETRIES=2
MAX_GROUNDING_RETRIES=1

# Whole-turn ceilings. The per-call OpenAI timeout does not bound a turn, since
# planning, dispatch, two workers and grounding are a dozen calls each within
# their own limit.
TURN_TIMEOUT_SECONDS=300
MAX_LLM_CALLS_PER_TURN=20

# Circuit breakers: end a worker loop early rather than spending its whole
# budget on calls that are getting nowhere.
MAX_CONSECUTIVE_TOOL_ERRORS=3
MAX_UNPRODUCTIVE_ITERATIONS=2
